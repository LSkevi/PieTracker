# Backend environment variables — copy this file to .env and fill in the values.

# Google Gemini API key used for OCR receipt processing.
GEMINI_API_KEY=

# Secret used to sign JWT access tokens. Use a long, random string in production.
PIETRACKER_SECRET_KEY=

# PostgreSQL connection string, e.g.:
# postgresql://user:password@host:5432/pietracker
DATABASE_URL=

# Comma-separated list of allowed CORS origins (the deployed frontend URL).
# Defaults to local dev origins when unset. Example:
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=
