# Frontend environment variables — copy this file to .env and fill in the values.
# Note: Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Base URL of the backend API. Defaults to http://localhost:8000 in dev and
# must be set to the deployed backend URL in production (e.g. on Vercel).
VITE_API_URL=

# Currency rates come from frankfurter.dev (free, no API key required), with a
# built-in static fallback table when the API is unavailable.
